# Server mode (achieve / modded)
SERVER_MODE=achieve

# Required - Factorio account (https://factorio.com/profile)
FACTORIO_USERNAME=your_username
FACTORIO_TOKEN=your_token

# Required - RCON password (auto-generated by install.sh)
FACTORIO_RCON_PASSWORD=changeme

# Optional - Server settings (used when server-settings.json doesn't exist)
FACTORIO_SERVER_NAME=My Dockerio Server
FACTORIO_SERVER_DESCRIPTION=Powered by Dockerio
FACTORIO_GAME_PASSWORD=
FACTORIO_AFK_KICK=30
FACTORIO_ADMINS=admin1,admin2

# Feature flags
FACTORIO_DISABLE_BLUEPRINTS=false
FACTORIO_AUTO_RESET=true
FACTORIO_PLAYER_MONITOR=true

# Timelapse (modded mode only)
GCS_TIMELAPSE_BUCKET=dockerio-timelapse
